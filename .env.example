# Copia este archivo a .env y ajusta los valores
# El archivo .env NO debe subirse al repositorio (ya esta en .gitignore)

# ============================================================
# DESARROLLO LOCAL (valores por defecto, podes dejarlo asi)
# ============================================================
DEBUG=True
SECRET_KEY=django-insecure-cambiar-en-produccion-tumomito-erp-2026
ALLOWED_HOSTS=localhost,127.0.0.1

# Para SQLite (default) no hace falta DATABASE_URL.
# Para PostgreSQL local descomenta:
# DATABASE_URL=postgres://usuario:password@localhost:5432/tumomito

# ============================================================
# PRODUCCION (Render configura estas variables automaticamente)
# ============================================================
# DEBUG=False
# SECRET_KEY=<clave-aleatoria-larga>
# ALLOWED_HOSTS=tumomito-erp.onrender.com
# DATABASE_URL=postgres://...  (lo provee Render)
